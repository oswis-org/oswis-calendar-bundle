{% extends '@OswisOrgOswisCore/e-mail/pages/message.html.twig' %}

{% block html_title %}{{ email.subject|default('Přehled přihlášek') }}{% endblock %}

{% block content_outer %}
    {% if message|default %}
        <mj-text background-color="#f8d7da" color="#721c24" padding="12px 16px" font-weight="700">
            {{ message }}
        </mj-text>
    {% endif %}
    <mj-raw>
        {% include '@OswisOrgOswisCalendar/other/participant-list/participant-list.html.twig' %}
    </mj-raw>
{% endblock %}
