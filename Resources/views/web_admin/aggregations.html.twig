{% extends '@OswisOrgOswisCore/web_admin/page-skeleton-web-admin.html.twig' %}

{% block html_title %}{{ page_title|default(pageTitle|default('Agregace')) }} :: ADMIN{% endblock %}

{% set page = "message" %}

{#
   Renders one ECharts time-series chart with three line series (created /
   deleted / active) per year. The three field names are passed in so the
   same macro can render both the running-sum chart and the per-day-delta
   chart from the same controller data.
#}
{% macro echarts_chart(dom_id, aggregations, field_created, field_deleted, field_active) %}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const chartDom = document.getElementById('{{ dom_id }}');
            const myChart = echarts.init(chartDom);

            function isFullscreen(element) {
                return screenfull.element === element;
            }

            async function fullscreen(element) {
                if (isFullscreen(element)) {
                    myChart?.setOption({
                        toolbox: {
                            feature: {
                                myFullScreen: {
                                    icon: 'path://M7,14H5v5h5v-2H7v-3zm-2-4h2V7h3V5H5v5zm12,7h-3v2h5v-5h-2v3zM14,5v2h3v3h2V5h-5z',
                                }
                            }
                        }
                    });
                    return await screenfull.exit();
                }
                myChart?.setOption({
                    toolbox: {
                        feature: {
                            myFullScreen: {
                                icon: 'path://m5,16h3v3h2v-5h-5v2zm3-8h-3v2h5v-5h-2v3zm6,11h2v-3h3v-2h-5v5zm2-11v-3h-2v5h5v-2h-3z',
                            }
                        }
                    }
                });
                return await screenfull.request(chartDom);
            }

            const option = {
                grid: {left: 40, top: 60, right: 40, bottom: 30,},
                tooltip: {trigger: 'axis',},
                legend: {top: 5, left: 'center', padding: [5, 40, 5, 40]},
                toolbox: {
                    orient: 'vertical',
                    feature: {
                        dataZoom: {yAxisIndex: 'none',},
                        saveAsImage: {show: true, title: 'Uložit', pixelRatio: 3},
                        magicType: {type: ['line', 'bar'], title: {line: 'line', bar: 'bar'}},
                        myFullScreen: {
                            show: true,
                            title: 'Fullscreen',
                            icon: 'path://M7,14H5v5h5v-2H7v-3zm-2-4h2V7h3V5H5v5zm12,7h-3v2h5v-5h-2v3zM14,5v2h3v3h2V5h-5z',
                            onclick: function () {
                                fullscreen(chartDom);
                            },
                        },
                    },
                },
                xAxis: {
                    type: 'time',
                    axisPointer: {
                        label: {
                            formatter: label => {
                                const date = new Date(label.value);
                                return date.getDate() + '. ' + (date.getMonth() + 1) + '. ';
                            },
                        }
                    },
                    axisLabel: {
                        formatter: {
                            year: '',
                            month: '1. {M}.',
                            day: '{d}. {M}.',
                            hour: '{HH}:{mm}',
                            minute: '{HH}:{mm}',
                            second: '{HH}:{mm}:{ss}',
                            millisecond: '{hh}:{mm}:{ss} {SSS}',
                        },
                        fontWeight: "bold",
                    },
                },
                yAxis: {
                    type: 'value',
                },
                series: [
                    {% for aggregation in aggregations|filter(agg => agg.days|length > 0) %}
                        {% set i = loop.index0 %}
                        {% set width = (3.5 - i * 0.5) %}
                        {% set channel = (150 + i * 15) %}
                        {% set alpha = (1 - i * 0.2) %}
                        {
                            name: '{{ aggregation.event.startYear }}',
                            color: 'rgba(0, {{ channel }}, 0, {{ alpha }})',
                            lineStyle: {width: {{ width }}},
                            type: 'line',
                            symbol: 'none',
                            smooth: true,
                            data: {{ attribute(aggregation, field_created)|raw }},
                            emphasis: {focus: 'series'},
                        },
                        {
                            name: '{{ aggregation.event.startYear }} ✗',
                            color: 'rgba({{ channel }}, 0, 0, {{ alpha }})',
                            lineStyle: {width: {{ width }}},
                            type: 'line',
                            symbol: 'none',
                            smooth: true,
                            data: {{ attribute(aggregation, field_deleted)|raw }},
                            emphasis: {focus: 'series'},
                        },
                        {
                            name: '{{ aggregation.event.startYear }} ✓',
                            color: 'rgba(0, 0, {{ channel }}, {{ alpha }})',
                            lineStyle: {width: {{ width }}},
                            type: 'line',
                            symbol: 'none',
                            smooth: true,
                            data: {{ attribute(aggregation, field_active)|raw }},
                            emphasis: {focus: 'series'},
                        },
                    {% endfor %}
                ]
            };
            option && myChart.setOption(option);
            new ResizeObserver(myChart.resize).observe(chartDom);
        }, false);
    </script>
{% endmacro %}

{% block javascripts %}
    <script src="https://cdn.jsdelivr.net/npm/echarts@5.5.0/dist/echarts.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/screenfull.js/5.2.0/screenfull.min.js"></script>
    {{ _self.echarts_chart('chart',  aggregations, 'created_attendees_sum_chart', 'deleted_attendees_sum_chart', 'active_attendees_sum_chart') }}
    {{ _self.echarts_chart('chart2', aggregations, 'created_attendees_chart',     'deleted_attendees_chart',     'active_attendees_chart') }}
{% endblock javascripts %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        table.list td {
            text-align: right;
        }
    </style>
{% endblock stylesheets %}

{% block body_content %}

    <div class="container-fluid" style="overflow-x: auto; overflow-y: visible;">
        <div class="row" style="min-width: 600px; overflow-y: visible; z-index: 40;">
            <div class="col-12" id="chartDiv">
                <div id="chart" style="aspect-ratio: 22/9; margin: 3em auto; background: white;"></div>
            </div>
            <div class="col-12" id="chart2Div">
                <div id="chart2" style="aspect-ratio: 22/9; margin: 3em auto; background: white;"></div>
            </div>
        </div>
    </div>

    <main class="container" id="main-content-container">
        <div class="row">
            <div class="col-12">
                {% for aggregation in aggregations|filter(agg => agg.days|length > 0) %}
                    <div>
                        <h3>{{ aggregation.event.name }}</h3>
                        <table class="list">
                            <thead>
                            <tr>
                                <th>Datum</th>
                                <th colspan="2">Vytvořené</th>
                                <th colspan="2">Smazané</th>
                                <th colspan="2">Aktivní</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for day in aggregation.days %}
                                <tr>
                                    <td><strong>{{ day.date_human }}</strong></td>
                                    <td style="color: rgb(40, 220, 40);">{{ day.created_attendees }}</td>
                                    <td style="color: rgb(40, 220, 40);"><strong>{{ day.created_attendees_sum }}</strong></td>
                                    <td style="color: red;">{{ day.deleted_attendees }}</td>
                                    <td style="color: red;"><strong>{{ day.deleted_attendees_sum }}</strong></td>
                                    <td style="color: blue;">{{ day.active_attendees }}</td>
                                    <td style="color: blue;"><strong>{{ day.active_attendees_sum }}</strong></td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endfor %}
            </div>
        </div>
    </main>
{% endblock %}
