{% extends '@OswisOrgOswisCore/web_admin/page-skeleton-web-admin.html.twig' %}

{% block html_title %}{{ page_title|default(pageTitle) }}{% endblock %}

{% block body_content %}
    <main class="container" style="padding-bottom: 6rem;">
        <div style="display: flex; align-items: center; gap: .75rem; flex-wrap: wrap; margin-bottom: .25rem;">
            <h2 style="margin: 0;">
                {{ pageTitle|default('Upravit událost') }}
                {% if event.deletedAt|default %}
                    <span class="badge bg-danger" style="font-size: .55em; vertical-align: middle;">SMAZÁNO</span>
                {% endif %}
            </h2>
            <a href="{{ path('oswis_org_oswis_calendar_web_admin_event', { eventSlug: event.slug }) }}"
               class="btn btn-sm btn-outline-secondary">← Zpět na přehled</a>
        </div>

        {{ form_start(form, { attr: { novalidate: 'novalidate', class: 'event-edit-form' } }) }}

        <fieldset style="border: 1px solid #dee2e6; border-radius: .375rem; padding: 1rem 1.25rem; margin-bottom: 1rem;">
            <legend style="font-size: 1rem; font-weight: 600; padding: 0 .5rem; width: auto; margin-bottom: .5rem;">Základní údaje</legend>
            <div class="row">
                <div class="col-12 col-md-6 mb-3">{{ form_row(form.name) }}</div>
                <div class="col-12 col-md-6 mb-3">{{ form_row(form.shortName) }}</div>
            </div>
            <div class="row">
                <div class="col-12 col-md-8 mb-3">{{ form_row(form.slug) }}</div>
                <div class="col-6 col-md-2 mb-3">{{ form_row(form.color) }}</div>
                <div class="col-6 col-md-2 mb-3 d-flex align-items-end">{{ form_row(form.publicOnWeb) }}</div>
            </div>
        </fieldset>

        <fieldset style="border: 1px solid #dee2e6; border-radius: .375rem; padding: 1rem 1.25rem; margin-bottom: 1rem;">
            <legend style="font-size: 1rem; font-weight: 600; padding: 0 .5rem; width: auto; margin-bottom: .5rem;">Termín a kapacita</legend>
            <div class="row">
                <div class="col-12 col-md-6 mb-3">{{ form_row(form.startDate) }}</div>
                <div class="col-12 col-md-6 mb-3">{{ form_row(form.endDate) }}</div>
            </div>
            <div class="row">
                <div class="col-12 col-md-6 mb-3">{{ form_row(form.baseCapacity) }}</div>
                <div class="col-12 col-md-6 mb-3">{{ form_row(form.fullCapacity) }}</div>
            </div>
        </fieldset>

        <fieldset style="border: 1px solid #dee2e6; border-radius: .375rem; padding: 1rem 1.25rem; margin-bottom: 1rem;">
            <legend style="font-size: 1rem; font-weight: 600; padding: 0 .5rem; width: auto; margin-bottom: .5rem;">Texty</legend>
            <div class="row">
                <div class="col-12 mb-3">{{ form_row(form.description) }}</div>
            </div>
            <div class="row">
                <div class="col-12 mb-3">{{ form_row(form.note) }}</div>
            </div>
        </fieldset>

        <div style="position: sticky; bottom: 0; background: rgba(255,255,255,.95); border-top: 1px solid #dee2e6; padding: .75rem 0; margin-top: 1rem; display: flex; gap: .5rem; justify-content: flex-end;">
            <a href="{{ path('oswis_org_oswis_calendar_web_admin_event', { eventSlug: event.slug }) }}"
               class="btn btn-outline-secondary">Zrušit</a>
            {{ form_row(form.submit, { attr: { class: 'btn btn-primary' } }) }}
        </div>
        {{ form_end(form) }}
    </main>
{% endblock %}
