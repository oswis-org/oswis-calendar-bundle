{% extends '@OswisOrgOswisCore/web_admin/page-skeleton-web-admin.html.twig' %}

{% block html_title %}{{ page_title }}{% endblock %}

{% set activeTab = app.request.query.get('tab')|default('groups') %}
{% if activeTab not in ['groups', 'categories', 'templates'] %}
    {% set activeTab = 'groups' %}
{% endif %}

{% block body_content %}
    <main class="container-fluid" style="padding: 1rem 1.25rem 3rem;">
        <h2>{{ pageTitle }}</h2>
        <p class="text-muted" style="max-width: 60rem;">
            Konfigurace odchozích systémových e-mailů pro účastníky: <strong>skupiny</strong> definují
            kdy a komu se posílá, <strong>kategorie</strong> seskupují skupiny podle typu, <strong>šablony</strong>
            obsahují HTML/text. Edit přímo v DB už není potřeba.
        </p>

        {# Tabs — much more readable than three tall tables stacked in one view. #}
        {% set tabs = [
            { value: 'groups',     label: 'Mail-skupiny',    count: groups|length },
            { value: 'categories', label: 'Kategorie',       count: categories|length },
            { value: 'templates',  label: 'Twig šablony',    count: templates|length },
        ] %}
        <div style="margin: 1.5rem 0 1rem; display: flex; gap: .25rem; border-bottom: 2px solid #006FAD; flex-wrap: wrap;">
            {% for tab in tabs %}
                <a href="{{ path('oswis_org_oswis_calendar_web_admin_mail_config', { tab: tab.value }) }}"
                   class="btn btn-sm"
                   style="border-radius: .375rem .375rem 0 0; {{ activeTab == tab.value ? 'background: #006FAD; color: white;' : 'background: #f8f9fa; color: #006FAD;' }}">
                    {{ tab.label }}
                    <span class="badge" style="background: rgba(255,255,255,.3); margin-left: .25rem;">{{ tab.count }}</span>
                </a>
            {% endfor %}
        </div>

        {% if activeTab == 'groups' %}
            <table class="list" style="width: 100%;">
                <thead>
                    <tr>
                        <th style="width: 3rem;">ID</th>
                        <th>Název</th>
                        <th style="width: 12rem;">Typ</th>
                        <th>Šablona</th>
                        <th>Kategorie</th>
                        <th>Událost</th>
                        <th style="width: 4rem; text-align: center;" title="Automatické odeslání">Auto</th>
                        <th style="width: 6rem; text-align: center;" title="Posílat jen aktivním účastníkům">Jen aktivní</th>
                        <th style="width: 6rem;"></th>
                    </tr>
                </thead>
                <tbody>
                    {% for g in groups %}
                        <tr>
                            <td>{{ g.id }}</td>
                            <td><strong>{{ g.name|default('—') }}</strong></td>
                            <td><code style="font-size: .85em;">{{ g.type|default('—') }}</code></td>
                            <td>{{ g.twigTemplate ? g.twigTemplate.name : '—' }}</td>
                            <td>{{ g.category ? g.category.name : '—' }}</td>
                            <td>{{ g.event ? (g.event.shortName ?: g.event.name) : '— (globální)' }}</td>
                            <td style="text-align: center;">{{ g.automaticMailing ? '✓' : '—' }}</td>
                            <td style="text-align: center;">{{ g.onlyActive ? '✓' : '—' }}</td>
                            <td>
                                <a class="btn btn-sm btn-outline-primary"
                                   href="{{ path('oswis_org_oswis_calendar_web_admin_mail_group_edit', { id: g.id }) }}">✎ Upravit</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="9" style="text-align: center; color: #6c757d;">Žádné mail-skupiny.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        {% elseif activeTab == 'categories' %}
            <table class="list" style="width: 100%;">
                <thead>
                    <tr>
                        <th style="width: 3rem;">ID</th>
                        <th>Název</th>
                        <th style="width: 14rem;">Typ</th>
                        <th style="width: 6rem; text-align: center;">Priorita</th>
                        <th style="width: 18rem;">Slug</th>
                        <th style="width: 6rem;"></th>
                    </tr>
                </thead>
                <tbody>
                    {% for c in categories %}
                        <tr>
                            <td>{{ c.id }}</td>
                            <td><strong>{{ c.name|default('—') }}</strong></td>
                            <td><code style="font-size: .85em;">{{ c.type|default('—') }}</code></td>
                            <td style="text-align: center;">{{ c.priority|default('—') }}</td>
                            <td><code style="font-size: .85em;">{{ c.slug|default('—') }}</code></td>
                            <td>
                                <a class="btn btn-sm btn-outline-primary"
                                   href="{{ path('oswis_org_oswis_calendar_web_admin_mail_category_edit', { id: c.id }) }}">✎ Upravit</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="6" style="text-align: center; color: #6c757d;">Žádné kategorie.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        {% elseif activeTab == 'templates' %}
            <p style="margin-bottom: .75rem;">
                <a class="btn btn-sm btn-success"
                   href="{{ path('oswis_org_oswis_calendar_web_admin_mail_template_new') }}">+ Nová šablona / blok</a>
            </p>
            <table class="list" style="width: 100%;">
                <thead>
                    <tr>
                        <th style="width: 3rem;">ID</th>
                        <th>Název</th>
                        <th style="width: 8rem;">Druh</th>
                        <th style="width: 18rem;">Slug</th>
                        <th>Cesta</th>
                        <th style="width: 11rem; text-align: center;">Inline obsah?</th>
                        <th style="width: 6rem;"></th>
                    </tr>
                </thead>
                <tbody>
                    {% for t in templates %}
                        <tr>
                            <td>{{ t.id }}</td>
                            <td><strong>{{ t.name|default('—') }}</strong></td>
                            <td>
                                {% set kindLabels = {'system': 'Systémový', 'campaign': 'Kampaň', 'snippet': 'Blok', 'page': 'Stránka', 'pdf': 'PDF'} %}
                                {% if t.kind %}
                                    <span class="badge" style="background:#e7f1ff;color:#0a58ca;border:1px solid #b6d4fe;border-radius:.4em;padding:.1em .5em;font-size:.8em;">{{ kindLabels[t.kind]|default(t.kind) }}</span>
                                {% else %}—{% endif %}
                            </td>
                            <td><code style="font-size: .85em;">{{ t.slug|default('—') }}</code></td>
                            <td><code style="font-size: .85em;">{{ t.regularTemplateName|default('—') }}</code></td>
                            <td style="text-align: center;">
                                {% if t.textValue|default %}
                                    <span title="Inline HTML, {{ t.textValue|length }} znaků">✓ {{ t.textValue|length }} znaků</span>
                                {% else %}
                                    —
                                {% endif %}
                            </td>
                            <td>
                                <a class="btn btn-sm btn-outline-primary"
                                   href="{{ path('oswis_org_oswis_calendar_web_admin_mail_template_edit', { id: t.id }) }}">✎ Upravit</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="7" style="text-align: center; color: #6c757d;">Žádné šablony.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </main>
{% endblock %}
