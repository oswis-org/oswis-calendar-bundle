{# Unified participant list. Everything is in the query string (scope + filter + flags + expr
   + sort + page), so the view is shareable/bookmarkable. UI is progressive: the common path
   (pick scope, pick a filter pill) is always visible; power features (flag facets, boolean
   expression, sub-event depth) live in a collapsed "Pokročilé" panel so ordinary users aren't
   overwhelmed and the page stays compact. #}
{% set qbase = app.request.query.all %}
<div class="container participants-page">

    {# ---- PAGE TITLE ----------------------------------------------------- #}
    <h2 class="h4 mb-2 mt-1">Přehled přihlášek</h2>

    {# ---- SCOPE BAR — one event picker (year → turnus → all events) + the
           category switcher, grouped into a subtle toolbar so the whole scope
           reads as one clear zone instead of scattered chips + links. ------- #}
    <div class="d-flex flex-wrap align-items-center gap-2 mb-3 px-2 py-2"
         style="background:#f4f7fa; border:1px solid #e3e9f0; border-radius:6px;">
        <span class="small text-secondary fw-bold">Akce:</span>
        <select class="form-select form-select-sm w-auto" title="Výběr akce"
                onchange="if(this.value){location.href=this.value;}">
            <option value="{{ path('oswis_org_oswis_calendar_web_admin_participants_list', qbase|merge({allEvents: 1, eventSlug: null, events: null, page: null})) }}"
                {{ allEvents|default ? 'selected' : '' }}>— všechny akce —</option>
            {% for yearEvent in yearEvents|default([]) %}
                <option value="{{ path('oswis_org_oswis_calendar_web_admin_participants_list', qbase|merge({eventSlug: yearEvent.slug, events: null, allEvents: null, page: null})) }}"
                    {{ (event|default and event.slug == yearEvent.slug) ? 'selected' : '' }}>{{ yearEvent.name|default(yearEvent.slug) }}{{ (defaultEvent|default and defaultEvent.id == yearEvent.id) ? ' (výchozí)' : '' }}</option>
                {% for subEvent in yearEvent.subEvents %}
                    <option value="{{ path('oswis_org_oswis_calendar_web_admin_participants_list', qbase|merge({eventSlug: subEvent.slug, events: null, allEvents: null, page: null})) }}"
                        {{ (event|default and event.slug == subEvent.slug) ? 'selected' : '' }}>&nbsp;&nbsp;&nbsp;↳ {{ subEvent.name|default(subEvent.slug) }}</option>
                {% endfor %}
            {% endfor %}
        </select>

        {# Category switcher — preserves the rest of the query. #}
        {% if participantCategories|default %}
            <span class="small text-secondary ms-1 fw-bold">Typ:</span>
            <select class="form-select form-select-sm w-auto py-0" title="Typ účastníka"
                    onchange="if(this.value){location.href=this.value;}">
                <option value="{{ path('oswis_org_oswis_calendar_web_admin_participants_list', qbase|merge({participantCategorySlug: null, page: null})) }}"
                    {{ participantCategory|default ? '' : 'selected' }}>— typ účastníka —</option>
                {% for category in participantCategories %}
                    <option value="{{ path('oswis_org_oswis_calendar_web_admin_participants_list', qbase|merge({participantCategorySlug: category.slug, page: null})) }}"
                        {{ participantCategory|default and participantCategory.slug == category.slug ? 'selected' : '' }}>{{ category.name|default(category.slug) }}</option>
                {% endfor %}
            </select>
        {% endif %}

        {# Free-text search (server-side ?q=): name / e-mail / phone / variable symbol, diacritic-
           insensitive. Carries the current scope + filter + flags as hidden fields so the search
           narrows *within* what's already shown. #}
        <form method="get" action="{{ path('oswis_org_oswis_calendar_web_admin_participants_list') }}"
              class="d-flex align-items-center gap-1 ms-auto" role="search">
            {% for key, value in scopeParams %}
                {% if key != 'q' %}
                    {% if value is iterable %}
                        {% for item in value %}<input type="hidden" name="{{ key }}[]" value="{{ item }}">{% endfor %}
                    {% else %}
                        <input type="hidden" name="{{ key }}" value="{{ value }}">
                    {% endif %}
                {% endif %}
            {% endfor %}
            {% if activeFilter|default and activeFilter != 'all' %}<input type="hidden" name="filter" value="{{ activeFilter }}">{% endif %}
            {% for f in selectedFlags|default([]) %}<input type="hidden" name="flags[]" value="{{ f }}">{% endfor %}
            {% if advancedExpr|default %}<input type="hidden" name="expr" value="{{ advancedExpr }}">{% endif %}
            <input type="search" name="q" value="{{ q|default }}" class="form-control form-control-sm"
                   style="min-width: 15rem;" placeholder="🔎 Hledat: jméno · e-mail · telefon · VS">
            <button type="submit" class="btn btn-sm btn-primary">Hledat</button>
            {% if q|default %}
                <a class="btn btn-sm btn-outline-primary" title="Zrušit hledání"
                   href="{{ path('oswis_org_oswis_calendar_web_admin_participants_list', scopeParams|merge({q: null})) }}">✕</a>
            {% endif %}
        </form>
    </div>

    {# ---- STATS (scoped, compact one-liner) ------------------------------ #}
    {% if stats|default %}
        <div class="d-flex flex-wrap gap-2 mb-2 small">
            <span class="badge bg-primary">přihlášek {{ stats.total }}</span>
            <span class="badge bg-success">zaplaceno {{ stats.paid }}</span>
            <span class="badge bg-danger">nezaplaceno {{ stats.unpaid }}</span>
            <span class="badge bg-info text-dark">vybráno {{ stats.sumPaid }} Kč</span>
            <span class="badge bg-warning text-dark">zbývá {{ stats.sumRemaining }} Kč</span>
            {% if stats.deleted > 0 %}<span class="badge bg-dark">smazaných {{ stats.deleted }}</span>{% endif %}
        </div>
    {% endif %}

    {# ---- FILTER FORM (GET; hidden fields carry scope+sort so nothing is lost) #}
    {# Empty advanced fields are dropped before submit (disabled inputs aren't sent) so shared
       URLs stay clean — no trailing &expr=&depth=. Works for both the Submit button (onsubmit)
       and the auto-submitting pills (which call form.submit(), bypassing onsubmit). #}
    <script>
        function oswisStripEmptyFilter(form) {
            for (var i = 0; i < form.elements.length; i++) {
                var el = form.elements[i];
                if ((el.name === 'expr' || el.name === 'depth') && el.value === '') {
                    el.disabled = true;
                }
            }
        }
        function oswisSubmitFilter(input) {
            var form = input.form;
            oswisStripEmptyFilter(form);
            form.submit();
        }
    </script>
    <form method="get" action="{{ path('oswis_org_oswis_calendar_web_admin_participants_list') }}" class="mb-2"
          onsubmit="oswisStripEmptyFilter(this);">
        {% for key, value in scopeParams %}
            {% if key != 'depth' %}
                {% if value is iterable %}
                    {% for item in value %}<input type="hidden" name="{{ key }}[]" value="{{ item }}">{% endfor %}
                {% else %}
                    <input type="hidden" name="{{ key }}" value="{{ value }}">
                {% endif %}
            {% endif %}
        {% endfor %}

        {# Primary filter pills (always visible, the common case). #}
        <div class="btn-group btn-group-sm flex-wrap" role="group">
            {% for tab in filterTabs %}
                <input type="radio" class="btn-check" name="filter" id="flt-{{ tab.key }}" value="{{ tab.key }}"
                       autocomplete="off" onchange="oswisSubmitFilter(this)" {{ tab.active ? 'checked' : '' }}>
                <label class="btn btn-outline-primary" for="flt-{{ tab.key }}"
                       title="{{ tab.group }}">{{ tab.label }}</label>
            {% endfor %}
        </div>

        {# Active flag filters as removable chips — what's selected is visible without opening
           the panel; each ✕ links to the same view minus that one flag. #}
        {% set anyFlagSelected = selectedFlags|default([])|length > 0 %}
        {% if anyFlagSelected %}
            <div class="d-flex flex-wrap align-items-center gap-1 mt-2">
                <span class="small text-secondary">Aktivní příznaky:</span>
                {% for facet in flagFacets|default([]) %}
                    {% for flag in facet.flags|filter(f => f.selected|default) %}
                        <a class="badge bg-primary text-decoration-none" title="Odebrat tento příznak"
                           href="{{ path('oswis_org_oswis_calendar_web_admin_participants_list', scopeParams|merge({
                               filter: (activeFilter|default('all') != 'all' ? activeFilter : null),
                               expr: advancedExpr|default,
                               flags: selectedFlags|filter(s => s != flag.slug),
                               page: null,
                           })) }}">{{ flag.label }}&nbsp;✕</a>
                    {% endfor %}
                {% endfor %}
            </div>
        {% endif %}

        {# Flag facets — own collapsible "Příznaky"; open when something is selected. #}
        {% if flagFacets|default %}
            <details class="mt-2" {{ anyFlagSelected ? 'open' : '' }}>
                <summary class="small fw-bold" style="cursor:pointer;">Příznaky <span class="text-secondary fw-normal">(NEBO uvnitř kategorie, A napříč)</span></summary>
                <div class="card card-body py-2 mt-1">
                    <div class="facet-grid">
                        {% for facet in flagFacets %}
                            {% set selCount = facet.flags|filter(f => f.selected|default)|length %}
                            <div class="facet-card">
                                <div class="facet-head">
                                    <span>{{ facet.categoryName }}</span>
                                    {% if selCount > 0 %}<span class="facet-count" title="vybráno v této kategorii">{{ selCount }}</span>{% endif %}
                                </div>
                                {% for flag in facet.flags %}
                                    <label class="{{ flag.selected|default ? 'sel' : '' }}">
                                        <input type="checkbox" name="flags[]" value="{{ flag.slug }}" {{ flag.selected ? 'checked' : '' }}>{{ flag.label }}
                                    </label>
                                {% endfor %}
                            </div>
                        {% endfor %}
                    </div>
                    <div class="mt-2"><button type="submit" class="btn btn-sm btn-primary">Použít příznaky</button></div>
                </div>
            </details>
        {% endif %}

        {# Developer/power expression + sub-event depth — deeper, separate disclosure. #}
        <details class="mt-1" {{ (advancedExpr|default or depthOverride is not null) ? 'open' : '' }}>
            <summary class="small text-secondary" style="cursor:pointer;">Pokročilé <span class="fw-normal">(výraz, hloubka podakcí)</span></summary>
            <div class="card card-body py-2 mt-1">
                <div class="row g-2 align-items-end">
                    <div class="col-md-8">
                        <label class="small text-secondary d-block">Výraz (pro pokročilé, volitelné)</label>
                        <input type="text" name="expr" class="form-control form-control-sm" value="{{ advancedExpr|default }}"
                               placeholder="hasFlag('panske-m') or hasFlag('damske-m')">
                        <small class="text-secondary">{{ availableFunctions|default([])|join('(), ') }}()</small>
                    </div>
                    <div class="col-md-4">
                        <label class="small text-secondary d-block">Hloubka podakcí</label>
                        <select name="depth" class="form-select form-select-sm">
                            <option value="" {{ depthOverride is null ? 'selected' : '' }}>auto</option>
                            {% for d in 0..3 %}
                                <option value="{{ d }}" {{ (depthOverride is not null and depthOverride == d) ? 'selected' : '' }}>{{ d }}</option>
                            {% endfor %}
                        </select>
                    </div>
                </div>
                <div class="mt-2"><button type="submit" class="btn btn-sm btn-primary">Použít</button></div>
            </div>
        </details>

        {% if hasActiveFilter|default or depthOverride is not null %}
            <div class="mt-2">
                <a class="btn btn-sm btn-outline-primary" href="{{ path('oswis_org_oswis_calendar_web_admin_participants_list', scopeParams|merge({q: null})) }}">Zrušit všechny filtry</a>
            </div>
        {% endif %}

        {# Pills auto-submit; a Submit fallback for when JS is off. #}
        <noscript><button type="submit" class="btn btn-sm btn-primary mt-2">Použít</button></noscript>
    </form>

    {# ---- WARNINGS ------------------------------------------------------- #}
    {% if filterScopeWarning|default %}
        <div class="alert alert-warning py-1 px-2 small mb-2">
            Bez omezení akce se filtr aplikuje jen na <strong>načtenou stránku</strong>. Pro filtr přes vše zvol akci/typ nebo
            <a href="{{ path('oswis_org_oswis_calendar_web_admin_participants_list', qbase|merge({all: 1, page: null})) }}">zobraz vše</a>, příp. CSV.
        </div>
    {% elseif showAll|default and not scoped %}
        <div class="alert alert-warning py-1 px-2 small mb-2">Zobrazeno <strong>vše</strong> bez omezení — může být hodně dat.</div>
    {% endif %}

    {# ---- LIST TOOLBAR (count + sort + export) --------------------------- #}
    <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
        <strong>{{ participants|length }}</strong> <span class="small text-secondary">přihlášek</span>
        <select class="form-select form-select-sm w-auto py-0 ms-2" title="Řazení"
                onchange="if(this.value){location.href=this.value;}">
            {% set sortOpts = {'name': 'jméno', 'payment': 'zbývá zaplatit', 'created': 'datum přihlášky', 'id': 'ID'} %}
            {% for key, label in sortOpts %}
                <option value="{{ path('oswis_org_oswis_calendar_web_admin_participants_list', qbase|merge({sort: key, dir: null, page: null})) }}"
                    {{ sort == key ? 'selected' : '' }}>řadit: {{ label }}</option>
            {% endfor %}
        </select>
        <a class="btn btn-sm btn-outline-primary py-0" title="Obrátit pořadí"
           href="{{ path('oswis_org_oswis_calendar_web_admin_participants_list', qbase|merge({dir: (dir == 'asc' ? 'desc' : 'asc'), page: null})) }}">{{ dir == 'asc' ? '↑' : '↓' }}</a>

        <details class="d-inline-block ms-auto" style="position: relative;">
            <summary class="btn btn-sm btn-outline-primary py-0" style="cursor: pointer;">Export ▾</summary>
            <form method="get"
                  action="{{ path('oswis_org_oswis_calendar_web_admin_participants_list_csv') }}"
                  class="card card-body shadow" style="position: absolute; z-index: 1000; min-width: 16rem; text-align: left;">
                {# Scope as hidden fields — a GET form discards its action's query string. #}
                {% for key, value in scopeParams %}
                    {% if key not in ['sort', 'dir'] %}
                        {% if value is iterable %}
                            {% for item in value %}<input type="hidden" name="{{ key }}[]" value="{{ item }}">{% endfor %}
                        {% else %}
                            <input type="hidden" name="{{ key }}" value="{{ value }}">
                        {% endif %}
                    {% endif %}
                {% endfor %}
                <div style="max-height: 14rem; overflow: auto; margin-bottom: .5rem;">
                    {% set exportColumns = {
                        'id': 'ID', 'familyName': 'Příjmení', 'givenName': 'Křestní jméno', 'fullName': 'Celé jméno',
                        'variableSymbol': 'Variabilní symbol', 'event': 'Akce', 'category': 'Kategorie',
                        'email': 'E-mail', 'phone': 'Telefon', 'tShirt': 'Velikost trička', 'createdAt': 'Datum přihlášky',
                        'activated': 'Aktivováno', 'price': 'Celková cena', 'paidPrice': 'Zaplaceno [Kč]',
                        'remainingPrice': 'Zbývá [Kč]', 'paidPercentage': 'Zaplaceno [%]', 'deletedAt': 'Smazáno'
                    } %}
                    {% for key, label in exportColumns %}
                        <label class="d-block small" style="font-weight: normal;"><input type="checkbox" name="columns[]" value="{{ key }}" checked> {{ label }}</label>
                    {% endfor %}
                </div>
                <label class="small d-block mb-2">Formát:
                    <select name="format" class="form-select form-select-sm">
                        <option value="csv">CSV (Excel)</option>
                        <option value="csv-rfc">CSV (RFC 4180)</option>
                        <option value="pdf">PDF</option>
                    </select>
                </label>
                <button type="submit" class="btn btn-sm btn-primary">Exportovat</button>
            </form>
        </details>
        {% if is_granted('ROLE_ADMIN') %}
            <a class="small text-secondary" href="{{ path('oswis_org_oswis_calendar_web_admin_bulk_reassign') }}">hromadný přesun</a>
        {% endif %}
    </div>

    {# ---- TABLE ---------------------------------------------------------- #}
    {# Scoped compaction: trim only the vertical air between the stacked info lines
       in each cell (line-height + the tiny top-padding on .small). Nothing is hidden
       or removed — every field stays visible, the rows just breathe a little less.
       Scoped to .participant-list so the shared global .list CSS is untouched. #}
    <style>
        /* Comfortable (not cramped) vertical rhythm in the data cells. */
        table.participant-list td .block { line-height: 1.4; }
        table.participant-list td .block.small { padding-top: .12em; }
        table.participant-list ul { margin-top: .1em; margin-bottom: .1em; }
        table.participant-list li { line-height: 1.4; margin-bottom: .12em; }
        /* Actions column: snug, evenly-sized buttons. */
        table.participant-list td.actions { padding: .3em .35em; }
        table.participant-list td.actions .btn { font-size: .72rem; padding: 2px 4px; }
        /* The app theme maps Bootstrap "secondary" to the orange PřF colour (#EB6D25), so every
           text-secondary label/hint here renders orange — far too much orange noise. Calm the
           secondary *text* on this page to a neutral slate grey (controls are recoloured to the
           blue primary in the markup; notes keep their intentional orange highlight). */
        .participants-page .text-secondary { color: #5f6b7a !important; }
        /* Flag facets as an even card grid (replaces the ragged CSS-multicolumn). Each category
           is a self-contained card; selected options + a per-category count make the active
           filters obvious at a glance. */
        /* Masonry-style packing: cards flow top-to-bottom then wrap to the next column, filling
           vertical gaps (a tall category like "Velikost trička" no longer leaves blank space
           under its neighbours). break-inside keeps each card whole. */
        .participants-page .facet-grid {
            column-width: 12.5rem;
            column-gap: .55rem;
        }
        .participants-page .facet-card {
            border: 1px solid #e3e9f0; border-radius: 6px; background: #fbfdff;
            padding: .35rem .55rem .45rem;
            break-inside: avoid; -webkit-column-break-inside: avoid;
            display: inline-block; width: 100%; margin-bottom: .55rem;
        }
        .participants-page .facet-card .facet-head {
            display: flex; justify-content: space-between; align-items: center;
            font-weight: 600; font-size: .8rem; color: #2a3a4a;
            border-bottom: 1px solid #eef2f6; margin-bottom: .25rem; padding-bottom: .2rem;
        }
        .participants-page .facet-card label {
            display: block; font-weight: normal; font-size: .82rem; line-height: 1.55; cursor: pointer; margin: 0;
        }
        .participants-page .facet-card label.sel { font-weight: 600; color: #006FAD; }
        .participants-page .facet-card input { margin-right: .35rem; }
        .participants-page .facet-count {
            background: #006FAD; color: #fff; border-radius: 10px; font-size: .68rem;
            font-weight: 700; padding: 0 .42rem; line-height: 1.5;
        }
        .participants-page .adv-expr {
            border-top: 1px dashed #d8e0e8; margin-top: .7rem; padding-top: .6rem;
        }
    </style>
    <table class="list participant-list" style="table-layout: fixed; word-break: break-word;">
        {% include '@OswisOrgOswisCalendar/other/participant-list/parts/participant-list-head.html.twig' %}
        {% for participant in participants %}
            {% include '@OswisOrgOswisCalendar/other/participant-list/parts/participant-list-inner.html.twig' %}
        {% else %}
            <tbody><tr><td colspan="5" class="text-center bold">Žádné přihlášky odpovídající filtru.</td></tr></tbody>
        {% endfor %}
    </table>

    {# ---- PAGINATION (unscoped paginated view) --------------------------- #}
    {% if pagination|default %}
        <nav class="mt-2 d-flex gap-2 align-items-center">
            {% if pagination.hasPrev %}
                <a class="btn btn-sm btn-outline-primary" href="{{ path('oswis_org_oswis_calendar_web_admin_participants_list', qbase|merge({page: pagination.page - 1})) }}">← Předchozí</a>
            {% endif %}
            <span class="small">strana {{ pagination.page }}</span>
            {% if pagination.hasNext %}
                <a class="btn btn-sm btn-outline-primary" href="{{ path('oswis_org_oswis_calendar_web_admin_participants_list', qbase|merge({page: pagination.page + 1})) }}">Další →</a>
            {% endif %}
            <a class="btn btn-sm btn-outline-primary ms-2" href="{{ path('oswis_org_oswis_calendar_web_admin_participants_list', qbase|merge({all: 1, page: null})) }}">Zobrazit vše</a>
        </nav>
    {% endif %}

    {# Bulk-mail helper: all e-mail addresses on this view, comma-separated and ready to paste into
       an e-mail client's recipient field. Collapsed by default (was a permanent orange wall of text);
       the textarea makes select-all + copy easy. #}
    {% set emails = participants|map(p => p.contact.email|default(''))|filter(e => e != '') %}
    {% if emails|length %}
        <details class="mt-3">
            <summary style="cursor:pointer;">📋 E-mailové adresy pro hromadné rozeslání ({{ emails|length }})</summary>
            <textarea readonly rows="3" class="form-control form-control-sm mt-1" style="font-size:.8rem;"
                      onclick="this.select();">{{ emails|join(', ') }}</textarea>
            <div class="small text-secondary mt-1">Klikni do pole (vše se označí) a zkopíruj (Ctrl+C) do pole příjemců v e-mailovém klientovi.</div>
        </details>
    {% endif %}

</div>
