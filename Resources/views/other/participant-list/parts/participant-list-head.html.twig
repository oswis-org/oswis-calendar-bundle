{# Clickable column headers sort the list (toggle asc/desc); the active column shows ▲/▼.
   Macros are isolated, so sort/dir/qbase are passed in. qbase carries the rest of the query
   (scope, filter, flags, search) so sorting never drops the current view. #}
{% macro sortHeader(label, key, sort, dir, qbase) %}
    {% set isActive = (sort|default('name')) == key %}
    {% set nextDir = (isActive and (dir|default('asc')) == 'asc') ? 'desc' : 'asc' %}
    <a class="oswis-sort {{ isActive ? 'active' : '' }}"
       href="{{ path('oswis_org_oswis_calendar_web_admin_participants_list', qbase|merge({sort: key, dir: nextDir, page: null})) }}"
       title="Seřadit podle: {{ label }}">{{ label }}{% if isActive %} <span class="oswis-sort-arrow">{{ (dir|default('asc')) == 'asc' ? '▲' : '▼' }}</span>{% endif %}</a>
{% endmacro %}

<thead>
<tr>
    {% if is_granted('ROLE_ADMIN') %}
        {# Bulk-select column (Fáze G). Header checkbox = select/deselect all rendered rows. #}
        <th class="bulk-col" style="width: 3%; text-align: center; vertical-align: middle;">
            <input type="checkbox" id="bulkSelectAll" title="Vybrat / odznačit vše na stránce" aria-label="Vybrat vše">
        </th>
    {% endif %}
    <th style="width: 15%;">
        {{ _self.sortHeader('ID', 'id', sort|default('name'), dir|default('asc'), qbase) }}
        <span class="block small">{{ _self.sortHeader('Vytvořeno', 'created', sort|default('name'), dir|default('asc'), qbase) }}</span>
    </th>
    <th style="width: 44%;">
        {{ _self.sortHeader('Účastník, Událost', 'name', sort|default('name'), dir|default('asc'), qbase) }}
        <span class="block small">Poznámky</span>
    </th>
    <th style="width: 13%;">
        Příznaky
    </th>
    <th style="width: 16%;">
        {{ _self.sortHeader('Zaplaceno', 'payment', sort|default('name'), dir|default('asc'), qbase) }}
        <span class="block small">{{ _self.sortHeader('Cena', 'price', sort|default('name'), dir|default('asc'), qbase) }}</span>
    </th>
    <th class="actions" style="width: 9%;">
        Akce
    </th>
</tr>
</thead>
