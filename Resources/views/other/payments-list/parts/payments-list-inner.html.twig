<tbody>
<tr style="border-top: 2px solid grey;">
    <td>
        <strong>ID {{ payment.id|default }}</strong><br>
        {% if payment.externalId|default %}
            <small>EXT. ID: {{ payment.externalId|default }}</small><br>
        {% endif %}
        {% if payment.dateTime|default %}
            <small>{{ payment.dateTime|date("j. n. Y H:i")|default }}</small><br>
        {% endif %}
        {% if payment.import.id|default %}
            <small>IMPORT {{ payment.import.id|default('0') }}</small><br>
        {% endif %}
    </td>
    <td>
        {% set valueColor = payment.numericValue|default < 0 ? 'red' : 'green' %}
        <strong style="color: {{ valueColor }}">{{ payment.numericValue|default(0) }},- Kč</strong><br>
        <small>VS: {{ payment.variableSymbol|default }}</small><br>
        <small>{{ payment.type|default }}</small>
    </td>
    {% set assignedColor = payment.participant|default ? 'green' : 'red' %}
    {% set assignedBackgroundColor = payment.participant|default ? 'rgba(50,255,50,.2)' : 'rgba(255,50,50,.2)' %}
    <td style="background-color: {{ assignedBackgroundColor }};">
        <strong style="color: {{ assignedColor }};">
            {% if payment.participant.id|default %}
                {# cachedContact = denormalised contact FK (EAGER-fetched in the list query);
                   participant.name would call getContact() → load the participantContacts
                   collection per row (was 391 N+1 queries on this overview). #}
                {{ payment.participant.id|default(0) }} | {{ payment.participant.cachedContact.name|default('<nepojmenovaný>') }}
            {% else %}
                ⚠️ NEPŘIŘAZENO ⚠️
            {% endif %}
        </strong><br>
        <small>
            {% if payment.confirmedByMailAt|default %}
                {{ payment.confirmedByMailAt|date("j. n. Y, H:i") }}
            {% else %}
                Potvrzení neodesláno!
            {% endif %}
        </small>
    </td>
    {% if isAdmin|default(false) %}
        <td style="white-space: nowrap;">
            <a href="{{ path('oswis_org_oswis_calendar_web_admin_payment_edit', { id: payment.id }) }}"
               class="btn btn-sm btn-outline-primary">Upravit</a>
            {% if payment.participant is null %}
                <a href="{{ path('oswis_org_oswis_calendar_web_admin_payment_match', { id: payment.id }) }}"
                   class="btn btn-sm btn-warning">Spárovat</a>
            {% else %}
                <form method="post"
                      action="{{ path('oswis_org_oswis_calendar_web_admin_payment_unmatch', { id: payment.id }) }}"
                      style="display:inline">
                    <button class="btn btn-sm btn-outline-secondary"
                            type="submit"
                            onclick="return confirm('Opravdu odpojit účastníka od této platby?');">Odpojit</button>
                </form>
            {% endif %}
        </td>
    {% endif %}
</tr>
{% set noteColspan = isAdmin|default(false) ? 4 : 3 %}
{% if payment.errorMessage %}
    <tr>
        <td style="background-color: rgba(255,50,50,.2)" colspan="{{ noteColspan }}"><small>CHYBA: {{ payment.errorMessage }}</small>
        </td>
    </tr>
{% endif %}
{% if payment.note %}
    <tr>
        <td colspan="{{ noteColspan }}"><small>Poznámka: {{ payment.note }}</small></td>
    </tr>
{% endif %}
{% if payment.internalNote %}
    <tr>
        <td colspan="{{ noteColspan }}"><small>Interní poznámka: {{ payment.internalNote }}</small></td>
    </tr>
{% endif %}
</tbody>
