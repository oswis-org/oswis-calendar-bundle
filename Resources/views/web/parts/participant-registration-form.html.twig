{% set e = form.vars.value.event|default(event|default) %}
<header>
    <h2 class="text-uppercase mb-2">Nový účastník</h2>
</header>
{# Long-standing iOS Safari issue: form gets submitted multiple times on
   slow connections (user re-taps, browser auto-retries) → duplicate
   participants. data-oswis-submitting flag + button disable short-circuits
   the second tap; server-side dedup in ParticipantService::create catches
   genuine races. #}
{{ form_start(form, {'attr': {
    'data-oswis-once': 'true',
    'onsubmit': 'if (this.dataset.oswisSubmitting === "true") { event.preventDefault(); return false; } this.dataset.oswisSubmitting = "true"; this.querySelectorAll("button[type=submit]").forEach(function(b) { b.disabled = true; b.dataset.origLabel = b.textContent; b.textContent = "Odesílám…"; });'
}}) }}
{{ form_widget(form) }}
{{ form_end(form) }}
<footer class="mt-5 pt-5 mb-4">
    {% include '@OswisOrgOswisCalendar/web/parts/participant-registration-range-preview.html.twig' with {'event': e} %}
    {% set subEvents = e.subEvents|filter(e => e.publicOnWeb) %}
    {% if subEvents|length > 0 %}
        <div class="mt-2 mb-2">
            <p><strong>Jsou dostupné také dílčí akce:</strong></p>
            {% include '@OswisOrgOswisCalendar/web/parts/event-sub-events-list.html.twig'
                with {'subEvents': subEvents} %}
        </div>
    {% endif %}
    {% include '@OswisOrgOswisCalendar/web/parts/event-preview.html.twig' with {'event': e} %}
</footer>